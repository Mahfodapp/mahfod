DATABASE SCHEMA (Drizzle ORM — exact recovered schema)
typescript// src/db/schema.ts

import { sqliteTable, text, integer } from 'drizzle-orm/sqlite-core';

export const memos = sqliteTable('memos', {
  id:             text('id').primaryKey(),
  title:          text('title').notNull(),
  text:           text('text').notNull(),
  label:          text('label').notNull(),
  tags:           text('tags').notNull().default('[]'),         // JSON array
  relatedMemoId:  text('related_memo_id'),                      // chain link
  audioUri:       text('audio_uri'),
  imageUri:       text('image_uri'),
  createdAt:      text('created_at').notNull(),
  updatedAt:      text('updated_at').notNull().default(''),
  lastReviewedAt: text('last_reviewed_at'),
  reviewCount:    integer('review_count').notNull().default(0),
  stage:          text('stage').notNull().default('LEARNING'),  // LEARNING | REVIEWING | MASTERED
  isFavorite:     integer('is_favorite').notNull().default(0),
});

export const books = sqliteTable('books', {
  id:            text('id').primaryKey(),
  title:         text('title').notNull(),
  author:        text('author').notNull(),
  subject:       text('subject').notNull(),
  sectionLevels: text('section_levels').notNull(),             // JSON array
  createdAt:     text('created_at').notNull(),
});

export const notes = sqliteTable('notes', {
  id:           text('id').primaryKey(),
  bookId:       text('book_id').notNull().references(() => books.id, { onDelete: 'cascade' }),
  text:         text('text').notNull(),
  label:        text('label').notNull(),
  sectionTitle: text('section_title').notNull(),
  pageNumber:   text('page_number'),
  createdAt:    text('created_at').notNull(),
});

export const quranProgress = sqliteTable('quran_progress', {
  id:        text('id').primaryKey(),
  type:      text('type').notNull(),   // memorized | review | tatbeet | rep | tatbeet_history
  thumnId:   integer('thumn_id').notNull(),
  value:     text('value').notNull(),
  updatedAt: text('updated_at').notNull(),
});

export const lessonsMatns = sqliteTable('lessons_matns', {
  id:        text('id').primaryKey(),
  title:     text('title').notNull(),
  author:    text('author').notNull().default(''),
  subject:   text('subject').notNull().default(''),
  verses:    text('verses').notNull().default('[]'),           // JSON: [{num, text, audio_uri, explanation}]
  createdAt: text('created_at').notNull(),
});

export const kvStore = sqliteTable('kv_store', {
  key:       text('key').primaryKey(),
  value:     text('value').notNull(),
  updatedAt: text('updated_at').notNull(),
});

SM-2 SPACED REPETITION ALGORITHM
typescript// src/logic/sm2.ts

export type Stage = 'LEARNING' | 'REVIEWING' | 'MASTERED';

export interface SM2State {
  reviewCount:    number;
  easeFactor:     number;   // default: 2.5
  intervalDays:   number;   // default: 0
  nextReviewAt:   string | null;
  lastReviewedAt: string | null;
  stage:          Stage;
}

export interface Settings {
  initialRepetitions:   number;   // default: 10
  reinforceRepetitions: number;   // default: 5
  reviewRepetitions:    number;   // default: 5
  masteryThreshold:     number;   // default: 30 (days until MASTERED)
}

/** quality: 0 = forgot, 1 = hard, 2 = ok, 3 = easy */
export function calculateNextReview(
  state: SM2State,
  quality: 0 | 1 | 2 | 3,
  settings: Settings
): SM2State {
  const MIN_EF = 1.3;
  let { easeFactor, intervalDays, reviewCount } = state;

  if (quality < 2) {
    // Failed — reset interval
    intervalDays = 1;
  } else {
    if (reviewCount === 0)      intervalDays = 1;
    else if (reviewCount === 1) intervalDays = 6;
    else                        intervalDays = Math.round(intervalDays * easeFactor);

    // SM-2 ease factor update
    easeFactor = Math.max(
      MIN_EF,
      easeFactor + (0.1 - (3 - quality) * (0.08 + (3 - quality) * 0.02))
    );
  }

  reviewCount += 1;

  const nextDate = new Date();
  nextDate.setDate(nextDate.getDate() + intervalDays);

  // Stage progression
  let stage: Stage = state.stage;
  if (stage === 'LEARNING' && reviewCount >= settings.initialRepetitions) {
    stage = 'REVIEWING';
  }
  if (stage === 'REVIEWING' && reviewCount >= settings.masteryThreshold) {
    stage = 'MASTERED';
  }

  return {
    reviewCount,
    easeFactor,
    intervalDays,
    nextReviewAt:   nextDate.toISOString(),
    lastReviewedAt: new Date().toISOString(),
    stage,
  };
}

export function isDueForReview(memo: SM2State): boolean {
  if (!memo.nextReviewAt) return true;
  return new Date(memo.nextReviewAt) <= new Date();
}

VANISH MODES (progressive text fading — core feature)
typescriptexport type VanishMode = 'none' | 'opacity' | 'words' | 'all';

// 'none'    — text always visible
// 'opacity' — text opacity fades after each repetition (from 1.0 → 0.0 over vanishAllAfter reps)
// 'words'   — individual words replaced by '···' one by one per rep
// 'all'     — entire text hidden after vanishAllAfter repetitions
// Default: 'opacity', vanishAllAfter: 5


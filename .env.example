# ── MAHFOD App — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git (it's already in .gitignore).

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Gemini AI (Development only — in production use Supabase secret) ──────────
# In production: supabase secrets set GEMINI_API_KEY=your-key
# This is only used as a local dev fallback when SUPABASE_URL is NOT set.
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key-here

# ── Error Monitoring (Optional) ─────────────────────────────────────────────
# Get your DSN from https://sentry.io/ after creating a project
# EXPO_PUBLIC_SENTRY_DSN=https://your-dsn-here@sentry.io/project-id
